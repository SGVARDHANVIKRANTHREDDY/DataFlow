# ── Required ──────────────────────────────────────────────────────────────────
# Backend URL (server-side only — never sent to browser)
BACKEND_URL=http://localhost:8000/api/v1

# Public API URL (used by Next.js API routes server-side)
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# ── Observability (optional but recommended for production) ───────────────────
# Get DSN from https://sentry.io → New Project → Next.js
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Auth (auto-managed via HttpOnly cookies — no config needed) ───────────────
# Tokens are stored in HttpOnly cookies by /api/auth/* routes.
# Do NOT add JWT secrets here — that belongs on the backend only.

# ── Testing ───────────────────────────────────────────────────────────────────
TEST_USER_EMAIL=test@pipeline-studio.dev
TEST_USER_PASSWORD=TestPassword123
BASE_URL=http://localhost:3000
