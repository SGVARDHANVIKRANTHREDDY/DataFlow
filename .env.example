# ═══════════════════════════════════════════════════════════════
#  DATA PIPELINE STUDIO v10 — Environment Variables
# ═══════════════════════════════════════════════════════════════

SECRET_KEY=CHANGE_ME_64_CHAR_RANDOM_STRING
SECRET_KEY_PREVIOUS=
ANTHROPIC_API_KEY=sk-ant-...
ENVIRONMENT=production

POSTGRES_DB=dps
POSTGRES_USER=dps
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# POSTGRES_READ_HOST=replica.internal

MINIO_ROOT_USER=CHANGE_ME_MINIO_USER
MINIO_ROOT_PASSWORD=CHANGE_ME_MINIO_PASSWORD

# S3_USE_AIOBOTO3=false  # set true only after: pip install aioboto3

CORS_ORIGINS=http://localhost,https://yourdomain.com

FLOWER_USER=admin
FLOWER_PASSWORD=CHANGE_ME

# v10: bootstrap super-admin (auto-promoted at startup)
SUPER_ADMIN_EMAIL=admin@yourdomain.com

# Audit
AUDIT_HASH_CHAIN_ENABLED=true
AUDIT_GLOBAL_SEQUENCE_ENABLED=true

# DLQ
DLQ_MAX_REPLAYS=3
DLQ_REPLAY_BACKOFF_SECONDS=300
DLQ_POISON_THRESHOLD=3

# Execution dedup (include steps hash for granularity)
EXECUTION_DEDUP_INCLUDE_STEPS=true

DEBUG=false
